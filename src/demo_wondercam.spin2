{Spin2_v45}
'' =================================================================================================
''
''   File....... demo_wondercam.spin2
''   Purpose.... Unified interactive DEBUG "front panel" for the WonderCam driver - the reusable
''               framework (window, layers, dirty-flag loop, mode/LED interaction).  Per-mode result
''               views (all 11 applications) are added in sprint section 9; this file is section 8.
''   Authors.... Stephen M Moraco / Claude Code
''   E-mail..... stephen@ironsheep.biz
''   Started.... Jun 2026
''   Updated.... Jun 2026
''
''   Built with the crop-and-overlay (sprite-blit) technique documented in DOCs/dbg-display-theory/.
''   Artwork (the four BMP layers) and the layout CON block below are BOTH generated by
''   tools/gen_wondercam_panel.py so the art and this code cannot drift - re-run that generator and
''   paste its printed CON block here after any layout change, then recompile.
''
''   DUAL-ENVIRONMENT: compile here (pnut-ts -d); the WINDOWED run is HOST-ONLY:
''       pnut-ts -d -q src/demo_wondercam.spin2                 ' compile (either environment)
''       cd src && pnut-term-ts -r demo_wondercam.bin -b 2000000 ' run windowed (macOS host only)
''   Run from src/ so the bare 'wc_*.bmp' layer filenames resolve and the log lands in src/logs/.
''
'' =================================================================================================

con ' ---- Clock and DEBUG Serial ----

  _clkfreq   = 320_000_000                                      ' canonical P2 clock (skill-conventions P2_CLOCK_FREQ)
  DEBUG_BAUD = 2_000_000                                        ' runtime DEBUG baud; pnut-term-ts must match with -b 2000000


con ' ---- Bench I2C Wiring ----
  ' SET THESE to match your board at hardware turn-on

  PIN_SCL = 16                                                  ' I2C SCL pin (placeholder; confirm at bring-up)
  PIN_SDA = 17                                                  ' I2C SDA pin (placeholder; confirm at bring-up)
  BUS_KHZ = 400                                                 ' 100 / 400 / 1000 (WonderCam supports full speed)


con ' ---- Generated Panel Layout ----
  ' GENERATED by tools/gen_wondercam_panel.py, do not hand-edit

  ' Window geometry
  WIN_W = 480
  WIN_H = 320

  ' Layer numbers (load order). DEBUG commands use literal layer numbers; these document them.
  LAYER_BG   = 1                                            ' wc_panel_bg.bmp - static panel
  LAYER_FONT = 2                                            ' wc_font.bmp     - digit/glyph strip
  LAYER_MODE = 3                                            ' wc_modes.bmp    - mode-name strip
  LAYER_LED  = 4                                            ' wc_led.bmp      - LED-state strip

  ' Camera-view region (per-mode views from section 9 draw here)
  VIEW_X = 8
  VIEW_Y = 38
  VIEW_W = 304
  VIEW_H = 240

  ' Mode-name strip cell - srcY = funcId * MODE_CELL_H, srcX = 0
  MODE_SLOT_X = 320
  MODE_SLOT_Y = 48
  MODE_CELL_W = 152
  MODE_CELL_H = 24

  ' Digit/glyph font strip - srcX = glyphIndex * DIG_W, srcY = 0
  DIG_W = 16
  DIG_H = 24
  GLYPH_MINUS = 10
  GLYPH_PLUS  = 11
  GLYPH_DOT   = 12
  GLYPH_BLANK = 13

  ' Echo readout (live device mode-echo number) - right-aligned ECHO_DIGITS-wide field
  ECHO_X = 384
  ECHO_Y = 82
  ECHO_DIGITS = 2

  ' LED-state strip cell (header) - srcX = ledState * LED_W, srcY = 0
  LED_SLOT_X = 426
  LED_SLOT_Y = 6
  LED_W = 44
  LED_H = 20

  ' Generic info readout area (side panel, lower) - the section 9 per-mode readouts draw here
  INFO_X      = 320
  INFO_Y      = 120
  INFO_W      = 152
  INFO_H      = 168
  INFO_LINE_H = 28

' ---- end generated panel layout ----


con ' ---- Demo Control Constants ----

  KEY_ESC    = 27                                              ' Esc key code (quit)
  DIGIT_BASE = 10                                              ' base for decimal digit extraction
  LED_OFF_ST = 0                                              ' LED-state strip cell index, off
  LED_ON_ST  = 1                                              ' LED-state strip cell index, on
  POLL_MS    = 50                                             ' loop pacing (matches the device's natural refresh)

  ' --- section 9 per-mode view tunables ---
  CAM_RES_W     = 320                                         ' assumed camera result-coordinate width  - UNVERIFIED, correct at bring-up L5
  CAM_RES_H     = 240                                         ' assumed camera result-coordinate height - UNVERIFIED, correct at bring-up L5
  DEMO_SCAN_IDS = 32                                          ' views scan ids 0..DEMO_SCAN_IDS-1 (DISPLAY CAP - ids at/above this are not drawn)
  DEMO_SCAN_IDX = 8                                           ' and up to this many records per id for object/tag (DISPLAY CAP)
  PCT_FULL      = 100                                         ' probability shown as whole percent: raw * PCT_FULL / PROB_DIVISOR
  ID_DIGITS     = 4                                           ' readout field widths (font-strip cells)
  CNT_DIGITS    = 3
  PCT_DIGITS    = 3
  LEN_DIGITS    = 4
  INFO_VAL_DX   = 84                                          ' value column x-offset within the info area (labels sit left of it)


con ' ---- Readout Layout ----

  INFO_TEXT_DY = 4                                            ' text-baseline nudge for info-line labels
  FLAG_DIGITS  = 1                                            ' digit-field width for a single-flag readout


obj ' ---- Objects ----

  cam : "isp_wondercam"                                        ' the driver under test (alias 'cam'; 'wc' is the reserved PASM2 carry flag)
  i2c : "isp_i2c_singleton"                                    ' referenced ONLY for the PU_* pull-up constants (no methods called here)


var ' ---- Panel State ----

  long  activeMode                                            ' the mode WE selected (drives the mode-name sprite)
  long  ledState                                              ' LED_OFF_ST / LED_ON_ST
  long  lastEcho                                              ' last device-reported mode echo drawn (dirty trigger)
  long  dirty                                                 ' set when the composed frame must be re-flipped
  long  running                                               ' main-loop guard; cleared by the quit key

  ' scratch result records filled by the driver getters (single-threaded demo: one in flight at a time)
  cam.spatial_result_t  boxRec                                ' face / object / color
  cam.line_result_t     lineRec                               ' line-follow
  cam.tag_result_t      tagRec                                ' AprilTag (x,y,w,h + 6 pose floats)


pub main()
'' Front-panel entry point that brings up the bus, opens the window, sets an initial mode/LED state, then runs the interactive loop until Esc.
''

  cam.start(PIN_SCL, PIN_SDA, BUS_KHZ, i2c.PU_3K3)             ' dedicated bus; status surfaced via the echo readout
  setupWindow()

  activeMode := cam.FUNC_FIRST                                  ' start on the first application
  ledState   := LED_OFF_ST
  lastEcho   := cam.E_NAK                                       ' force the first echo draw
  running    := TRUE

  cam.setMode(activeMode)                                       ' adopt the initial mode (bounded; may take seconds on hardware)
  cam.setLed(ledState)
  dirty := TRUE

  runLoop()
  shutdown()


pri setupWindow()
' Create the PLOT window in manual/double-buffered mode (hidexy update) and load the four BMP layers once.
'
' Layer numbers are literal here (the reference-display idiom); see the LAYER_* CONs.

  debug(`plot wcam title 'WonderCam Front Panel' size `(WIN_W, WIN_H) pos 200 120 hidexy update)
  debug(`wcam layer 1 'wc_panel_bg.bmp')
  debug(`wcam layer 2 'wc_font.bmp')
  debug(`wcam layer 3 'wc_modes.bmp')
  debug(`wcam layer 4 'wc_led.bmp')
  debug(`wcam crop 1)                                          ' paint the full static background (CROP form a)
  debug(`wcam update)


pri runLoop() | keyCode
' Run the dirty-flag loop that polls the keyboard and device every tick, recomposing and flipping the frame only when something changed.
'
' Local Variables:
' @local keyCode - the keypress latched this tick (0 when none)

  repeat while running
    keyCode := 0
    debug(`wcam `pc_key(@keyCode))                            ' poll keyboard (MUST be last in its debug statement)
    if keyCode
      handleKey(keyCode)
    pollDevice()
    if dirty
      composeFrame()
      debug(`wcam update)                                     ' single atomic flip
      dirty := FALSE
    waitms(POLL_MS)


pri handleKey(code)
' Map a keypress to an action: SPACE / n cycle forward, p cycles back, l toggles the LED, Esc quits.
'
' @param code - the key code to dispatch on

  case code
    " ", "n", "N" : cycleMode(1)
    "p", "P"      : cycleMode(-1)
    "l", "L"      : toggleLed()
    KEY_ESC       : running := FALSE


pri cycleMode(delta) | newMode
' Advance the selected application by delta with wraparound across the 11 modes and ask the device to adopt it.
'
' @param delta - the signed step (+1 / -1); 'delta' not 'step' - 'step' is the reserved repeat-loop keyword
'
' Local Variables:
' @local newMode - the wrapped target mode before adoption
'
' The device's actual adoption is reflected by the echo readout (pollDevice).

  newMode := activeMode + delta
  if newMode > cam.FUNC_LAST
    newMode := cam.FUNC_FIRST
  if newMode < cam.FUNC_FIRST
    newMode := cam.FUNC_LAST
  activeMode := newMode
  cam.setMode(activeMode)                                       ' bounded call; return intentionally not gated here
  dirty := TRUE


pri toggleLed()
' Flip the fill-light state and push it to the device.

  if ledState == LED_OFF_ST
    ledState := LED_ON_ST
  else
    ledState := LED_OFF_ST
  cam.setLed(ledState)
  dirty := TRUE


pri pollDevice() | echo
' Run a fast per-tick device poll, latching the active-mode summary and reading the live active function for the echo readout.
'
' Local Variables:
' @local echo - the device's live active function this tick
'
' updateResult() latches the active-mode summary (consumed by the section 9 per-mode views);
' currentMode() reports the device's live active function. Only an echo change marks the frame
' dirty - the framework itself draws nothing else live.

  cam.updateResult()
  echo := cam.currentMode()
  if echo <> lastEcho
    lastEcho := echo
    dirty := TRUE


pri composeFrame()
' Compose one frame into the back buffer: mode-name sprite, live echo number, LED indicator, and the per-mode detail view.
'
' The cells are opaque and fixed-size, so each blit cleanly overwrites the prior frame's cell - no
' separate erase is needed for these slots.

  debug(`wcam crop 3 `(0, activeMode * MODE_CELL_H, MODE_CELL_W, MODE_CELL_H, MODE_SLOT_X, MODE_SLOT_Y))
  drawNum(lastEcho, ECHO_X, ECHO_Y, ECHO_DIGITS)
  debug(`wcam crop 4 `(ledState * LED_W, 0, LED_W, LED_H, LED_SLOT_X, LED_SLOT_Y))
  drawModeView()


pri drawModeView()
' Dispatch the section 9 per-mode result view selected by activeMode.
'
' Spatial modes (face/object/color/line/AprilTag) stroke live vector bounding boxes into the
' camera-view region from each record's x/y/w/h; classification-style modes (classification/feature/
' number/road-sign/QR/barcode) render numeric panels in the info area. The VIEW and INFO regions are
' erased-by-restore every frame (CROP form b from layer 1), so no stale art persists and a zero-count
' mode shows a clean frame with a 0 readout - the explicit "no detection" state.

  eraseView()
  eraseInfo()
  case activeMode
    cam.FUNC_FACE     : viewFace()
    cam.FUNC_OBJECT   : viewObject()
    cam.FUNC_COLOR    : viewColor()
    cam.FUNC_LINE     : viewLine()
    cam.FUNC_APRILTAG : viewTag()
    cam.FUNC_CLASSIFY : viewTopProb(cam.classTopId(),     cam.classTopProb())
    cam.FUNC_FEATURE  : viewTopProb(cam.featureTopId(),   cam.featureTopProb())
    cam.FUNC_NUMBER   : viewTopProb(cam.numberTopId(),    cam.numberTopProb())      ' number: UNVERIFIED until bring-up L5
    cam.FUNC_LANDMARK : viewTopProb(cam.landmarkTopId(),  cam.landmarkTopProb())    ' road-sign: UNVERIFIED until bring-up L5
    cam.FUNC_QRCODE   : viewPayload(cam.qrDetected(),      cam.qrLength())
    cam.FUNC_BARCODE  : viewPayload(cam.barcodeDetected(), cam.barcodeLength())
    other             : viewIdle()


pri eraseView()
' Restore the clean camera-view background (CROP form b: source rect copied back to the same spot).
  debug(`wcam crop 1 `(VIEW_X, VIEW_Y, VIEW_W, VIEW_H))


pri eraseInfo()
' Restore the clean info-panel background.
  debug(`wcam crop 1 `(INFO_X, INFO_Y, INFO_W, INFO_H))


pri infoVal(lineIx, readoutNum, nDigits)
' Blit a numeric readout in the value column of info line lineIx (font strip, layer 2).
'
' @param lineIx - the info-panel line index (0-based) to draw on
' @param readoutNum - the number to render in the value column
' @param nDigits - field width in glyphs
  drawNum(readoutNum, INFO_X + INFO_VAL_DX, INFO_Y + lineIx * INFO_LINE_H, nDigits)


pri viewX(camCoord) : vx
' Map a camera-frame X into the VIEW region, clamped to the frame (one place owns the X mapping).
'
' @param camCoord - the camera-frame X coordinate
' @returns vx - the clamped VIEW-region X pixel
  vx := VIEW_X + (camCoord * VIEW_W) / CAM_RES_W
  vx := (vx #> VIEW_X) <# (VIEW_X + VIEW_W - 1)


pri viewY(camCoord) : vy
' Map a camera-frame Y into the VIEW region, clamped to the frame (one place owns the Y mapping).
'
' @param camCoord - the camera-frame Y coordinate
' @returns vy - the clamped VIEW-region Y pixel
  vy := VIEW_Y + (camCoord * VIEW_H) / CAM_RES_H
  vy := (vy #> VIEW_Y) <# (VIEW_Y + VIEW_H - 1)


pri drawBox(camX, camY, camW, camH) | x0, y0, x1, y1
' Stroke one vector bounding box by mapping a camera record's x/y/w/h into the VIEW region and drawing the rectangle outline.
'
' @param camX - camera-frame box left X
' @param camY - camera-frame box top Y
' @param camW - camera-frame box width
' @param camH - camera-frame box height
'
' Local Variables:
' @local x0 - mapped left edge
' @local y0 - mapped top edge
' @local x1 - mapped right edge
' @local y1 - mapped bottom edge
'
' viewX/viewY clamp into the frame (default top-left, Y-down coordinates) so a stray/garbage record
' cannot scribble outside the camera view.
  x0 := viewX(camX)
  y0 := viewY(camY)
  x1 := viewX(camX + camW)
  y1 := viewY(camY + camH)
  debug(`wcam set `(x0, y0) line `(x1, y0) line `(x1, y1) line `(x0, y1) line `(x0, y0))


pri drawSpatialRec()
' Stroke a box from the shared spatial_result_t (x,y signed int16; w,h unsigned).
  drawBox(boxRec.x SIGNX 15, boxRec.y SIGNX 15, boxRec.w, boxRec.h)


pri drawLineRec() | x0, y0, x1, y1
' Stroke the detected line from the shared line_result_t (endpoints, signed int16).
'
' Local Variables:
' @local x0 - mapped start X
' @local y0 - mapped start Y
' @local x1 - mapped end X
' @local y1 - mapped end Y
  x0 := viewX(lineRec.start_x SIGNX 15)
  y0 := viewY(lineRec.start_y SIGNX 15)
  x1 := viewX(lineRec.end_x   SIGNX 15)
  y1 := viewY(lineRec.end_y   SIGNX 15)
  debug(`wcam set `(x0, y0) line `(x1, y1))


pri viewFace() | id, idx, total, learned, unlearned
' Draw the face view: boxes for learned faces (by id) and unlearned faces (by index); readout = total/known/new.
'
' Local Variables:
' @local id - learned-face id scan cursor
' @local idx - unlearned-face index scan cursor
' @local total - total detected face count
' @local learned - learned (known) face count
' @local unlearned - unlearned (new) face count
  debug(`wcam color green)
  total     := cam.numFaces()
  learned   := cam.numLearned()
  unlearned := cam.numUnlearned()
  repeat id from 0 to DEMO_SCAN_IDS - 1
    if cam.getFaceById(id, @boxRec) == cam.E_OK
      drawSpatialRec()
  if unlearned > 0
    repeat idx from 0 to unlearned - 1
      if cam.getUnlearnedFace(idx, @boxRec) == cam.E_OK
        drawSpatialRec()
  debug(`wcam color white)
  debug(`wcam set `(INFO_X, INFO_Y + 0 * INFO_LINE_H + INFO_TEXT_DY) text 'FACES')
  infoVal(0, total, CNT_DIGITS)
  debug(`wcam set `(INFO_X, INFO_Y + 1 * INFO_LINE_H + INFO_TEXT_DY) text 'KNOWN')
  infoVal(1, learned, CNT_DIGITS)
  debug(`wcam set `(INFO_X, INFO_Y + 2 * INFO_LINE_H + INFO_TEXT_DY) text 'NEW')
  infoVal(2, unlearned, CNT_DIGITS)


pri viewObject() | id, idx, total
' Draw the object view: boxes for every detected (id, index) record; readout = total count.
'
' Local Variables:
' @local id - object id scan cursor
' @local idx - per-id record index cursor
' @local total - total detected object count
  debug(`wcam color green)
  total := cam.numObjects()
  repeat id from 0 to DEMO_SCAN_IDS - 1
    repeat idx from 0 to DEMO_SCAN_IDX - 1
      if cam.getObject(id, idx, @boxRec) == cam.E_OK
        drawSpatialRec()
      else
        quit                                                  ' no more records for this id
  debug(`wcam color white)
  debug(`wcam set `(INFO_X, INFO_Y + INFO_TEXT_DY) text 'OBJS')
  infoVal(0, total, CNT_DIGITS)


pri viewColor() | id, total
' Draw the color view: a box per detected color id; readout = total count.
'
' Local Variables:
' @local id - color id scan cursor
' @local total - total detected color count
  debug(`wcam color green)
  total := cam.numColors()
  repeat id from 0 to DEMO_SCAN_IDS - 1
    if cam.getColor(id, @boxRec) == cam.E_OK
      drawSpatialRec()
  debug(`wcam color white)
  debug(`wcam set `(INFO_X, INFO_Y + INFO_TEXT_DY) text 'COLORS')
  infoVal(0, total, CNT_DIGITS)


pri viewLine() | id, total, drew
' Draw the line-follow view: stroke the first detected line; readout = count plus normalized angle/offset.
'
' Local Variables:
' @local id - line id scan cursor
' @local total - total detected line count
' @local drew - flag set once a line has been stroked
  debug(`wcam color green)
  total := cam.numLines()
  drew  := FALSE
  repeat id from 0 to DEMO_SCAN_IDS - 1
    if cam.getLine(id, @lineRec) == cam.E_OK
      drawLineRec()
      drew := TRUE
      quit
  debug(`wcam color white)
  debug(`wcam set `(INFO_X, INFO_Y + INFO_TEXT_DY) text 'LINES')
  infoVal(0, total, CNT_DIGITS)
  if drew
    debug(`wcam set `(INFO_X, INFO_Y + 1 * INFO_LINE_H + INFO_TEXT_DY) text 'ANGLE')
    infoVal(1, lineRec.angle SIGNX 15, ID_DIGITS)
    debug(`wcam set `(INFO_X, INFO_Y + 2 * INFO_LINE_H + INFO_TEXT_DY) text 'OFFSET')
    infoVal(2, lineRec.offset SIGNX 15, ID_DIGITS)


pri viewTag() | id, idx, total
' Draw the AprilTag view: boxes for every detected (id, index) record; readout = total count.
'
' Local Variables:
' @local id - tag id scan cursor
' @local idx - per-id record index cursor
' @local total - total detected tag count
'
' (The 6-DoF pose floats in each tag_result_t are available via the driver but not shown numerically.)
  debug(`wcam color green)
  total := cam.numTags()
  repeat id from 0 to DEMO_SCAN_IDS - 1
    repeat idx from 0 to DEMO_SCAN_IDX - 1
      if cam.getTag(id, idx, @tagRec) == cam.E_OK
        drawBox(tagRec.x SIGNX 15, tagRec.y SIGNX 15, tagRec.w, tagRec.h)
      else
        quit
  debug(`wcam color white)
  debug(`wcam set `(INFO_X, INFO_Y + INFO_TEXT_DY) text 'TAGS')
  infoVal(0, total, CNT_DIGITS)


pri viewTopProb(id, prob) | pct
' Draw a classification-style readout: top class id and its probability as a whole percent.
'
' @param id - the top class id to display
' @param prob - the raw probability (0..PROB_DIVISOR), or negative for none
'
' Local Variables:
' @local pct - probability rendered as a whole percent
  pct := 0
  if prob >= 0
    pct := (prob * PCT_FULL) / cam.PROB_DIVISOR                ' raw 0..PROB_DIVISOR -> 0..100
  debug(`wcam color white)
  debug(`wcam set `(INFO_X, INFO_Y + INFO_TEXT_DY) text 'TOP ID')
  infoVal(0, id, ID_DIGITS)
  debug(`wcam set `(INFO_X, INFO_Y + 1 * INFO_LINE_H + INFO_TEXT_DY) text 'PROB%')
  infoVal(1, pct, PCT_DIGITS)


pri viewPayload(detected, len) | shown
' Draw a QR / barcode readout: detected flag and payload length (the 4-digit field caps the shown length).
'
' @param detected - nonzero when a code was found
' @param len - the payload length to display
'
' Local Variables:
' @local shown - the normalized 0/1 found flag
  shown := 0
  if detected
    shown := 1
  debug(`wcam color white)
  debug(`wcam set `(INFO_X, INFO_Y + INFO_TEXT_DY) text 'FOUND')
  infoVal(0, shown, FLAG_DIGITS)
  debug(`wcam set `(INFO_X, INFO_Y + 1 * INFO_LINE_H + INFO_TEXT_DY) text 'LEN')
  infoVal(1, len, LEN_DIGITS)


pri viewIdle()
' Show the idle view: no active application - the camera view and info panel stay clean (already erased above).


pri drawNum(readoutNum, xLeft, yTop, nDigits) | mag, isNeg, col, dx, glyph
' Blit readoutNum right-aligned into an nDigits-wide field at (xLeft, yTop) using the font strip.
'
' @param readoutNum - the number to render
' @param xLeft - left pixel of the field
' @param yTop - top pixel of the field
' @param nDigits - field width in glyphs
'
' Local Variables:
' @local mag - working magnitude
' @local isNeg - sign flag ('isNeg' not 'neg' - 'neg' is the reserved PASM2 instruction)
' @local col - current column (col 0 = least-significant, rightmost cell)
' @local dx - x offset of the current glyph cell
' @local glyph - current glyph index into the font strip
'
' Leading zeros render as blank cells; a negative value shows a leading minus glyph.
' Fixed-width output means each call fully overwrites the prior number in that field.

  if nDigits > 0
    mag := readoutNum
    isNeg := FALSE
    if readoutNum < 0
      isNeg := TRUE
      mag := abs(readoutNum)                                   ' abs(), never the || operator (pnut-ts)
    repeat col from 0 to nDigits - 1                           ' col 0 = least-significant (rightmost) cell
      dx := xLeft + (nDigits - 1 - col) * DIG_W
      if col == 0 or mag > 0
        glyph := mag // DIGIT_BASE                             ' a real digit
      elseif isNeg
        glyph := GLYPH_MINUS                                   ' sign sits just left of the magnitude
        isNeg := FALSE
      else
        glyph := GLYPH_BLANK                                   ' suppressed leading zero
      debug(`wcam crop 2 `(glyph * DIG_W, 0, DIG_W, DIG_H, dx, yTop))
      mag := mag / DIGIT_BASE


pri shutdown()
' Tear down cleanly: light off, bus released, and emit the end-of-session marker the windowed terminal watches for.
'
' The marker (P2_END_MARKER = DEBUG_END_SESSION) is sent as a text phrase to stay on {Spin2_v45}
' (the DEBUG_END_SESSION control constant would require {Spin2_v52}).

  cam.setLed(LED_OFF_ST)
  cam.stop()
  debug(`wcam update)
  debug("DEBUG_END_SESSION")


