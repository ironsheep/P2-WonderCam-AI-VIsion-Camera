{Spin2_v50}
'' =================================================================================================
''
''   File....... test_wondercam.spin2
''   Purpose.... Automatable regression top for the WonderCam driver (spec section 7.2).
''               Self-checks the bring-up subset that needs NO physical target in front of the lens
''               (L0 bus ACK, L1 version sanity, L2/L4 mode write/echo, L3 chunked-read integrity,
''               L4 per-mode summary-shape) and emits PASS / FAIL / SKIP to the DEBUG log. Every
''               check that could NOT be exercised here is NAMED in the coverage roll-call (no silent
''               gaps). L5 per-application record decode stays the MANUAL playbook (test-playbook,
''               sprint section 11) because it requires faces / tags / colors / signs in frame.
''   Authors.... Stephen M Moraco / Claude Code
''   E-mail..... stephen@ironsheep.biz
''   Started.... Jun 2026
''   Updated.... Jun 2026
''
''   DUAL-ENVIRONMENT: COMPILE here (pnut-ts); the behavioral RUN is HOST-ONLY (needs a P2 board with
''   the camera wired). In the container this only compiles clean - the L0-L4 self-checks execute at
''   hardware turn-on on the macOS host.
''       pnut-ts -l src/test_wondercam.spin2                     ' compile + listing (either environment)
''       cd src && pnut-term-ts -r test_wondercam.bin -b 2000000 ' run + capture log (macOS host only)
''
'' =================================================================================================

con { clock and DEBUG serial }

  _clkfreq   = 320_000_000                                       ' canonical P2 clock (skill-conventions P2_CLOCK_FREQ)
  DEBUG_BAUD = 2_000_000                                         ' runtime DEBUG baud; pnut-term-ts must match with -b 2000000


con { bench I2C wiring - SET THESE to match your board at hardware turn-on }

  PIN_SCL = 16                                                   ' I2C SCL pin (placeholder; confirm at bring-up L0)
  PIN_SDA = 17                                                   ' I2C SDA pin (placeholder; confirm at bring-up L0)
  BUS_KHZ = 400                                                  ' 100 / 400 / 1000 (WonderCam supports full speed)


con { harness sizing - test buffers as named constants (authoring guide 6.4) }

  ' L3 reads a region LARGER than one I2C chunk so the read crosses a 32-byte boundary and exercises
  ' the driver's CHUNK_AUTOINC path. The probe length must exceed cam.READ_CHUNK to cross a boundary;
  ' it is read two ways (one big read vs two chunk-sized reads) and the two must agree byte-for-byte.
  PROBE_LEN  = 2 * cam.READ_CHUNK                                ' two chunks: guaranteed to cross a chunk boundary whatever READ_CHUNK is set to
  L3_PROBE_ADDR = cam.REG_FW_VERSION                             ' $0000: the 16-byte version then the system-register area (static between back-to-back reads)


obj

  cam : "isp_wondercam"                                          ' the driver under test (alias 'cam'; 'wc' is reserved in pnut-ts)
  i2c : "isp_i2c_singleton"                                      ' referenced ONLY for the PU_* pull-up constant (no methods called here)


var { harness tally + scratch buffers }

  long  testsPassed                                             ' checks that matched expectation
  long  testsFailed                                             ' checks that did NOT match (expected-vs-actual printed)
  long  testsSkipped                                            ' automatable checks skipped because a precondition was absent (device NAK)
  long  testsGaps                                               ' checks NAMED as not-automatable-here (manual / host / needs targets)

  byte  verBuf[cam.FW_VERSION_LEN + 1]                          ' L1 firmware-version string (+1 guarantees a NUL terminator for zstr_)
  byte  probeA[PROBE_LEN]                                       ' L3 big single read
  byte  probeB[PROBE_LEN]                                       ' L3 two stitched chunk-sized reads


pub main() | startStatus

'' Regression entry point. Single straight-line flow (single exit, authoring guide 5.5): open the bus,
'' run the automatable L0-L4 self-checks if the camera answers, then ALWAYS name the coverage gaps and
'' print the tally - so a device-absent run still reports honestly instead of silently doing nothing.

  setup()

  ' L0 - bus presence: the camera must ACK its address for any later check to mean anything.
  startStatus := cam.start(PIN_SCL, PIN_SDA, BUS_KHZ, i2c.PU_3K3)
  evalValue(startStatus, @"L0: bus ACK at 0x32 (start)", cam.E_OK)

  if startStatus == cam.E_OK
    checkVersion()                                             ' L1
    checkModeEchoes()                                          ' L2 / L4 write + echo
    checkLargeRead()                                           ' L3 chunk-integrity
    checkSummaryShapes()                                       ' L4 summary latch + per-mode guard
  else
    skipDeviceChecks()                                         ' device did not ACK: name every check we could not run

  cam.setLed(FALSE)                                            ' best-effort: leave the fill light off (NAK harmlessly if absent)
  cam.stop()

  reportGaps()                                                ' ALWAYS: name what this top cannot exercise (no silent coverage gaps)
  showCounts()
  debug("DEBUG_END_SESSION")                                  ' end-of-session marker (text phrase; the control constant needs {Spin2_v52})


pri setup()

'' Banner. The tally longs (testsPassed/Failed/Skipped/Gaps) auto-zero at load, so no explicit reset.

  debug("==================================================")
  debug("WonderCam driver regression - automatable L0-L4 subset")
  debug("driver VERSION (MM_mm_pp) = ", uhex_(cam.VERSION))
  debug("L5 per-application decode is the MANUAL playbook (needs targets) - see sprint section 11")
  debug("==================================================")


con { L1 - firmware version (register read + 16-bit framing + address byte order) }

pub checkVersion() | nRead

'' L1: read the 16 ASCII version bytes at REG_FW_VERSION. A correct length AND all-printable bytes
'' prove the 16-bit register framing and the address byte order (ADDR_LOW_FIRST) are right - garbage
'' here is the classic byte-order-reversed symptom. Retires the L1 row of the bring-up table.

  nRead := cam.firmwareVersion(@verBuf)
  evalValue(nRead, @"L1: firmwareVersion() byte count", cam.FW_VERSION_LEN)
  evalBool(isPrintableAscii(@verBuf, cam.FW_VERSION_LEN), @"L1: version bytes are printable ASCII", TRUE)
  debug("  L1 version string = '", zstr_(@verBuf), "'")


con { L2 / L4 - mode write + echo round-trip for all 11 applications }

pub checkModeEchoes() | funcId

'' L2/L4: write each of the 11 function ids and confirm the device echoes it back (setMode polls the
'' echo internally, bounded). Also confirms the write path and that an out-of-range id is rejected.
'' The LED WRITE returns a byte count here; its VISUAL effect is a named manual gap (reportGaps).

  debug("--- L2/L4: mode write + echo round-trip (funcs ", udec_(cam.FUNC_FIRST), "..", udec_(cam.FUNC_LAST), ") ---")
  funcId := cam.FUNC_FIRST
  repeat while funcId <= cam.FUNC_LAST                          ' while-form so an empty range scans nothing
    debug("  mode ", udec_(funcId), " (", zstr_(modeName(funcId)), ")")
    evalValue(cam.setMode(funcId), @"    setMode() adopted (E_OK)", cam.E_OK)
    evalValue(cam.currentMode(),   @"    currentMode() echo matches", funcId)
    funcId++

  ' write-path sanity (one register, single byte): the count returns, the glow is eyeballed at the bench
  evalNonNeg(cam.setLed(TRUE),  @"L2: setLed(on) write accepted")
  evalNonNeg(cam.setLed(FALSE), @"L2: setLed(off) write accepted")

  ' deliberate error: an out-of-range function id must be rejected, not written (authoring guide 6.6)
  evalValue(cam.setMode(cam.FUNC_LAST + 1), @"L2: setMode(out-of-range) rejected", cam.E_ARG)


con { L3 - chunked read integrity (the chunk strategy gates every read > 32 bytes) }

pub checkLargeRead() | nBig, nLo, nHi

'' L3: read a PROBE_LEN-byte region (> one chunk) two ways and require they AGREE byte-for-byte:
''   A) one big read   - exercises the driver's CHUNK_AUTOINC walk across the 32-byte boundary
''   B) two chunk-sized reads, each separately addressed - the reference the big read must reproduce
'' If they disagree, chunk auto-increment is wrong and EVERY read over 32 bytes is corrupt. Also checks
'' the known 16-byte version sub-pattern survives at the front of the big read. Retires the L3 row.

  if PROBE_LEN <= cam.READ_CHUNK
    skipCheck(@"L3: probe <= READ_CHUNK, cannot cross a chunk boundary - widen PROBE_LEN")
  else
    nBig := cam.readReg(L3_PROBE_ADDR, @probeA, PROBE_LEN)
    evalValue(nBig, @"L3: single big read returns full length", PROBE_LEN)

    nLo := cam.readReg(L3_PROBE_ADDR,                  @probeB,                  cam.READ_CHUNK)
    nHi := cam.readReg(L3_PROBE_ADDR + cam.READ_CHUNK, @probeB + cam.READ_CHUNK, PROBE_LEN - cam.READ_CHUNK)
    evalValue(nLo + nHi, @"L3: two chunk reads return full length", PROBE_LEN)

    evalBool(buffersEqual(@probeA, @probeB, PROBE_LEN), @"L3: big read == two chunk reads (auto-increment)", TRUE)
    evalBool(buffersEqual(@probeA, @verBuf, cam.FW_VERSION_LEN), @"L3: big read front 16B == known version", TRUE)


con { L4 - per-mode summary latch + shape + wrong-mode guard }

pub checkSummaryShapes() | funcId, nSumm

'' L4: for each mode, setMode then updateResult and confirm the summary latched at the EXPECTED size
'' for that mode (classification 128, feature 64, else 48), and that the mode's primary accessor returns
'' a non-error in-bounds value (counts/top-id, not E_MODE). Then confirm the wrong-mode guard fires.
'' This validates the latch + guard logic WITHOUT physical targets; actual values are an L5 manual gap.

  debug("--- L4: per-mode summary-shape sanity ---")
  funcId := cam.FUNC_FIRST
  repeat while funcId <= cam.FUNC_LAST
    cam.setMode(funcId)
    nSumm := cam.updateResult()
    debug("  mode ", udec_(funcId), " (", zstr_(modeName(funcId)), ")")
    evalValue(nSumm, @"    updateResult() summary size as planned", expectedSummSize(funcId))
    evalNonNeg(primaryResult(funcId), @"    primary accessor returns a value (not E_MODE)")
    funcId++

  ' wrong-mode guard: in FACE mode an OBJECT accessor must self-reject, never read face bytes as objects
  cam.setMode(cam.FUNC_FACE)
  cam.updateResult()
  evalValue(cam.numObjects(), @"L4: numObjects() in face mode -> E_MODE", cam.E_MODE)
  evalBool(cam.anyObject(),   @"L4: anyObject() in face mode -> FALSE", FALSE)


con { device-absent path - name every automatable check we could not run }

pri skipDeviceChecks()

'' Reached when start() did not get an ACK. The L0-L4 self-checks are automatable but their precondition
'' (a responding camera) is absent, so they are SKIPPED-and-named rather than silently omitted.

  debug("--- device did not ACK at 0x32: automatable checks SKIPPED (precondition absent) ---")
  skipCheck(@"L1: firmware-version sanity (no device)")
  skipCheck(@"L2/L4: mode write + echo round-trip (no device)")
  skipCheck(@"L3: chunked-read integrity (no device)")
  skipCheck(@"L4: per-mode summary-shape sanity (no device)")


con { coverage roll-call - what this regression top CANNOT exercise (no silent gaps) }

pri reportGaps()

'' Spec 7.2: the regression top names everything it could not exercise. These are not failures - they
'' are the boundary between the automatable subset (above) and the manual host work (bring-up + L5).

  debug("--- COVERAGE GAPS: not automatable in this top (named, not failures) ---")
  gap(@"L2: LED fill-light VISUAL confirmation - eyeballed at the bench (host)")
  gap(@"L5: per-application RECORD DECODE (all 11 apps) - manual playbook, needs targets in frame (section 11)")
  gap(@"L5: detection COUNTS and record FIELD values - depend on targets; only shape/guard checked here")
  gap(@"L5: AprilTag record stride + line endpoints-vs-box interpretation - need a tag/line in frame")
  gap(@"L5: number + landmark decode - UNVERIFIED (Python-only source, no vendor C path)")
  gap(@"L1: ADDR_LOW_FIRST alternate byte order - only the compiled-in order is exercised")
  gap(@"L3: CHUNK_AUTOINC=FALSE re-address fallback - only the compiled-in path is exercised; flip + re-run to cover")


con { tally }

pri showCounts()

'' Final scoreboard. A green run is pass>0 and fail==0; skip/gaps are expected and named above.

  debug("==================================================")
  debug("RESULTS  pass=", udec_(testsPassed), "  fail=", udec_(testsFailed), "  skip=", udec_(testsSkipped), "  gaps-named=", udec_(testsGaps))
  if testsFailed == 0
    debug("OVERALL: PASS (automatable L0-L4 subset)")
  else
    debug("OVERALL: FAIL - see expected-vs-actual lines above")
  debug("==================================================")


con { assertion helpers - self-contained (this greenfield repo has no shared test-utils object yet) }

  ' Semantics mirror the authoring-guide 6.3 evaluate* family: a status/value check prints expected and
  ' actual on failure; a boolean check tests against TRUE/FALSE; ranges and non-negativity have intent-
  ' naming variants. Labels are passed as @"..." pointers and read like statements of intent.

pri evalValue(actual, pLabel, expected)

'' Pass when actual == expected; on failure print BOTH values so a regression is diagnosable from the
'' log alone (not just "fail"). Use for status codes and exact numeric values.

  if actual == expected
    testsPassed++
    debug("  PASS  ", zstr_(pLabel), "  (== ", sdec_(expected), ")")
  else
    testsFailed++
    debug("  FAIL  ", zstr_(pLabel), "  expected=", sdec_(expected), " actual=", sdec_(actual))


pri evalBool(bActual, pLabel, bExpected)

'' Pass when both operands have the same truthiness. Use only for values that are already boolean
'' (any*/*Detected predicates), never for status codes (authoring guide 6.3).

  if (bActual <> FALSE) == (bExpected <> FALSE)
    testsPassed++
    debug("  PASS  ", zstr_(pLabel))
  else
    testsFailed++
    debug("  FAIL  ", zstr_(pLabel), "  expected=", sdec_(bExpected), " actual=", sdec_(bActual))


pri evalNonNeg(actual, pLabel)

'' Pass when actual is a non-negative success value (>= E_OK); a negative driver error code fails.
'' Use where the exact value depends on what is in frame but a SUCCESS/ERROR distinction is automatable.

  if actual >= cam.E_OK
    testsPassed++
    debug("  PASS  ", zstr_(pLabel), "  (= ", sdec_(actual), ")")
  else
    testsFailed++
    debug("  FAIL  ", zstr_(pLabel), "  expected>=0 actual=", sdec_(actual))


pri skipCheck(pLabel)

'' An automatable check whose precondition is absent this run (e.g. no device). Named, never silent.

  testsSkipped++
  debug("  SKIP  ", zstr_(pLabel))


pri gap(pLabel)

'' A check that is inherently not automatable in this top (manual / host / needs physical targets).
'' Named so coverage boundaries are explicit; counted separately from pass/fail/skip.

  testsGaps++
  debug("  GAP   ", zstr_(pLabel))


con { small pure helpers }

pri isPrintableAscii(pBuf, len) : bAllPrintable | idx, ch

'' TRUE if every one of len bytes at pBuf is a printable ASCII char ($20..$7E). A reversed-byte-order
'' or NAK'd version read shows up here as non-printable bytes.

  bAllPrintable := TRUE
  idx := 0
  repeat while idx < len
    ch := BYTE[pBuf + idx]
    if ch < $20 or ch > $7E
      bAllPrintable := FALSE
      quit
    idx++


pri buffersEqual(pLeft, pRight, len) : bEqual | idx

'' TRUE if the first len bytes at pLeft and pRight are identical.

  bEqual := TRUE
  idx := 0
  repeat while idx < len
    if BYTE[pLeft + idx] <> BYTE[pRight + idx]
      bEqual := FALSE
      quit
    idx++


pri expectedSummSize(funcId) : nBytes

'' The updateResult() summary size the driver reads for funcId (mirrors the driver's summaryReadPlan:
'' classification 128, feature-learning 64, every other mode 48).

  case funcId
    cam.FUNC_CLASSIFY : nBytes := cam.SUMM_SIZE_CLASS
    cam.FUNC_FEATURE  : nBytes := cam.SUMM_SIZE_FEATURE
    other             : nBytes := cam.SUMM_SIZE_STD


pri primaryResult(funcId) : valOrErr

'' The natural "did this mode latch something readable" accessor for funcId: a detection count for the
'' spatial modes, the argmax id for the classification-style modes, the payload length for QR/barcode.
'' Returns a non-negative value when the mode is active and in-bounds, or a negative driver error code.

  case funcId
    cam.FUNC_FACE     : valOrErr := cam.numFaces()
    cam.FUNC_OBJECT   : valOrErr := cam.numObjects()
    cam.FUNC_CLASSIFY : valOrErr := cam.classTopId()
    cam.FUNC_FEATURE  : valOrErr := cam.featureTopId()
    cam.FUNC_COLOR    : valOrErr := cam.numColors()
    cam.FUNC_LINE     : valOrErr := cam.numLines()
    cam.FUNC_APRILTAG : valOrErr := cam.numTags()
    cam.FUNC_QRCODE   : valOrErr := cam.qrLength()
    cam.FUNC_BARCODE  : valOrErr := cam.barcodeLength()
    cam.FUNC_NUMBER   : valOrErr := cam.numberTopId()
    cam.FUNC_LANDMARK : valOrErr := cam.landmarkTopId()
    other             : valOrErr := cam.E_MODE


pri modeName(funcId) : pName

'' Human-readable label for a function id, for the per-mode log headers.

  case funcId
    cam.FUNC_FACE     : pName := @"face"
    cam.FUNC_OBJECT   : pName := @"object"
    cam.FUNC_CLASSIFY : pName := @"classify"
    cam.FUNC_FEATURE  : pName := @"feature"
    cam.FUNC_COLOR    : pName := @"color"
    cam.FUNC_LINE     : pName := @"line"
    cam.FUNC_APRILTAG : pName := @"apriltag"
    cam.FUNC_QRCODE   : pName := @"qrcode"
    cam.FUNC_BARCODE  : pName := @"barcode"
    cam.FUNC_NUMBER   : pName := @"number"
    cam.FUNC_LANDMARK : pName := @"landmark"
    other             : pName := @"?"


con { license }

